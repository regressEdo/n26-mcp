# N26 MCP Server — credentials
#
# Option A: plain credentials (copy this file to .env and fill in real values)
N26_USERNAME=your.email@example.com
N26_PASSWORD=your-n26-password

# Option B: 1Password CLI secret references (requires `op run --env-file .env --` wrapper)
# N26_USERNAME=op://Vault/Item/N26_USERNAME
# N26_PASSWORD=op://Vault/Item/N26_PASSWORD
